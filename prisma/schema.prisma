generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String            @id @default(cuid())
  authId    String            @unique
  name      String
  email     String            @unique
  role      Role              @default(USER)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  sessions  PracticeSession[]

  @@map("users")
}

model QuestionPackage {
  id        String         @id @default(cuid())
  name      String
  section   Section
  createdAt DateTime       @default(now())
  isActive  Boolean        @default(true)
  questions BankQuestion[]

  @@unique([name, section])
  @@map("question_packages")
}

model BankQuestion {
  id               String            @id @default(cuid())
  section          Section
  packageId        String?
  sourceType       QuestionSource
  passage          String?
  text             String
  optionA          String
  optionB          String
  optionC          String
  optionD          String
  correctAnswer    String
  explanation      String
  createdAt        DateTime          @default(now())
  package          QuestionPackage?  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  sessionQuestions SessionQuestion[]

  @@map("bank_questions")
}

model PracticeSession {
  id               String            @id @default(cuid())
  userId           String
  section          Section
  isRandom         Boolean           @default(false)
  totalQ           Int
  correctQ         Int               @default(0)
  score            Int?
  status           String            @default("ongoing")
  startedAt        DateTime          @default(now())
  completedAt      DateTime?
  user             User              @relation(fields: [userId], references: [id])
  answers          SessionAnswer[]
  sessionQuestions SessionQuestion[]

  @@map("practice_sessions")
}

model SessionQuestion {
  id         String          @id @default(cuid())
  sessionId  String
  questionId String
  order      Int             @default(0)
  answer     SessionAnswer?
  question   BankQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  session    PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@map("session_questions")
}

model SessionAnswer {
  id                String          @id @default(cuid())
  sessionId         String
  sessionQuestionId String          @unique
  userAnswer        String
  isCorrect         Boolean
  answeredAt        DateTime        @default(now())
  session           PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionQuestion   SessionQuestion @relation(fields: [sessionQuestionId], references: [id], onDelete: Cascade)

  @@map("session_answers")
}

enum Role {
  ADMIN
  USER
}

enum Section {
  READING
  GRAMMAR
  LISTENING
  SIMULATION
}

enum QuestionSource {
  ORIGINAL
  GENERATED
}
