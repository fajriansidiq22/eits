generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum Section {
  READING
  GRAMMAR
  LISTENING
  SIMULATION
}

enum QuestionSource {
  ORIGINAL
  GENERATED
}

// ── Users ──────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  authId    String   @unique // Supabase Auth UUID
  name      String
  email     String   @unique
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  sessions PracticeSession[]

  @@map("users")
}

// ── Question Bank ──────────────────────────────────

// Paket soal. Misalnya: "Paket A", "Paket B" untuk section "READING".
model QuestionPackage {
  id        String   @id @default(cuid())
  name      String   // A, B, C... Z, AA, AB...
  section   Section
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  questions BankQuestion[]

  @@unique([name, section])
  @@map("question_packages")
}

model BankQuestion {
  id            String           @id @default(cuid())
  section       Section
  packageId     String?          // Bisa null kalau Original dan tidak dimasukkan paket? Atau selalu di paket. Asumsikan Generated ada paketnya.
  package       QuestionPackage? @relation(fields: [packageId], references: [id], onDelete: Cascade)
  sourceType    QuestionSource
  
  passage       String?          @db.Text
  text          String           @db.Text
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String           // "A" | "B" | "C" | "D"
  explanation   String           @db.Text
  createdAt     DateTime         @default(now())

  sessionQuestions SessionQuestion[]

  @@map("bank_questions")
}

// ── Practice Sessions ───────────────────────────────
model PracticeSession {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  section     Section
  isRandom    Boolean   @default(false)
  totalQ      Int
  correctQ    Int       @default(0)
  score       Int?      // persentase, null = belum selesai
  status      String    @default("ongoing") // ongoing | completed
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  sessionQuestions SessionQuestion[]
  answers          SessionAnswer[]

  @@map("practice_sessions")
}

// Menghubungkan PracticeSession dengan BankQuestion
model SessionQuestion {
  id          String          @id @default(cuid())
  sessionId   String
  session     PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId  String
  question    BankQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order       Int             @default(0)

  answer      SessionAnswer?

  @@unique([sessionId, questionId])
  @@map("session_questions")
}

// ── Session Answers ─────────────────────────────────
model SessionAnswer {
  id                String          @id @default(cuid())
  sessionId         String
  session           PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionQuestionId String          @unique
  sessionQuestion   SessionQuestion @relation(fields: [sessionQuestionId], references: [id], onDelete: Cascade)
  userAnswer        String          // "A" | "B" | "C" | "D"
  isCorrect         Boolean
  answeredAt        DateTime        @default(now())

  @@map("session_answers")
}
